# =============================================================================
# Chrono Lexicanum — environment variables
# Copy this file to `.env.local` and fill in real values. .env.local is gitignored.
# =============================================================================

# --- Supabase (Postgres) ----------------------------------------------------
# Get these from: Supabase Dashboard → your project → Settings → API
# DATABASE_URL is from: Settings → Database → "Connection string" (URI mode)
# Use the "Transaction pooler" URL (port 6543) for both runtime and migrations.
# Free-tier "Direct connection" is IPv6-only and unreachable from most networks;
# the pooler endpoint is IPv4 and works for everything we need at v1 scale.
# URL-encode special characters in the password (* → %2A, , → %2C, ! → %21).

DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres"

# Public, safe to ship in client bundles. Used for read-only browser access.
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# Server-side only. Used by API routes / scripts that need to bypass RLS.
# NEVER prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# --- App ---------------------------------------------------------------------
# Used in Open Graph meta and absolute URLs. Set per environment.
# Local: http://localhost:3000
# Vercel preview: leave blank (Vercel injects VERCEL_URL automatically)
# Production: https://chrono-lexicanum.vercel.app (or your custom domain)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Shared secret for `POST /api/revalidate` (on-demand cache invalidation after
# ingestion/apply runs — Report 144 § P.6). Any long random string, e.g.
# `openssl rand -hex 32`. Unset = the endpoint is disabled (503). Server-only —
# NEVER prefix with NEXT_PUBLIC_.
REVALIDATE_TOKEN=

# --- Hardcover.app (optional) -----------------------------------------------
# User-Token für die Hardcover GraphQL API. Optional — wenn leer, deaktiviert
# sich der Hardcover-Crawler still (kein Crash, kein 0-Diff).
# Token-Beschaffung:
#   1. Account auf https://hardcover.app anlegen (kostenlos).
#   2. Settings → Developer / API → Bearer-Token generieren.
#   3. Hier einsetzen.
# NIEMALS committen.

HARDCOVER_API_TOKEN=

# --- Anthropic API (Phase 3c — optional) ------------------------------------
# API-Key für die Claude-LLM-Anreicherungs-Schicht (Sonnet 4.6 + Web-Search).
# Optional — wenn leer, deaktiviert sich der LLM-Crawler still (kein Crash;
# Diff zeigt Per-Book-Sources wie 3b, ohne LLM-Felder).
# Token-Beschaffung:
#   1. Account auf https://console.anthropic.com anlegen.
#   2. „API Keys" → „Create Key" — z.B. `chrono-lexicanum-ingestion`.
#   3. Hier einsetzen (Format: sk-ant-...).
#   4. Optional: Spending-Limit auf $5 setzen, bevor du den ersten 20-Buch-Test
#      startest (Sicherheits-Stop). 20-Buch-Test-Cost-Erwartung: ~$1.50–4.00.
# NIEMALS committen.

ANTHROPIC_API_KEY=

# Modell-Wahl konfigurierbar; default ist Sonnet 4.6. Ein Switch zu Haiku ist
# ein .env-Edit, kein Code-Change. Nur setzen wenn ein anderes Modell gewünscht.
# INGEST_LLM_MODEL=claude-sonnet-4-6

# Brief 110 — Podcast-Ingest (scripts/ingest-podcast.ts) nutzt ein eigenes,
# vom Buch-Pipeline-Modell unabhängiges Knob. Wenn leer, fällt es auf
# INGEST_LLM_MODEL / dessen Default zurück. Step-1-Pilot lief mit Sonnet 4.6.
# PODCAST_LLM_MODEL=claude-sonnet-4-6

# --- YouTube Data API v3 (Brief 130 — luetin09 YouTube-Source) ---------------
# API-Key für den YouTube-Source-Adapter (src/lib/ingestion/podcast/youtube.ts).
# Nur für Shows mit "source": "youtube" in scripts/seed-data/podcast-shows.json
# nötig (RSS-Shows ignorieren ihn). NUR METADATEN — der Adapter lädt niemals
# Video/Audio herunter, nur reine HTTP-GETs gegen die Data API v3.
# Token-Beschaffung:
#   1. Google-Cloud-Projekt anlegen (console.cloud.google.com).
#   2. „YouTube Data API v3" aktivieren (APIs & Services → Library).
#   3. Credentials → „Create credentials" → „API key". (Quota für diesen
#      Use-Case trivial: Voll-Backfill ≈ wenige Dutzend Units gegen 10 000/Tag.)
#   4. Hier einsetzen. NIEMALS committen.
YOUTUBE_API_KEY=

# --- Atlas Admin-Gate (Task 1 Auth-Foundation) ------------------------------
# HTTP-Basic-Auth-Credentials für `/atlas/**` (siehe src/proxy.ts).
# Single-User, ein Passwort für alles. Bei gültigen Credentials reicht der
# Proxy zusätzlich einen `x-atlas-admin: 1`-Request-Header an `/map/**`
# durch — daher steht /map auch dann im Matcher, wenn es selbst öffentlich
# bleibt (kein 401 auf /map).
#
# ATLAS_USER ist optional (Default: `philipp`).
# ATLAS_PASS MUSS in Produktion gesetzt sein — ist es leer/ungesetzt, liefert
# `/atlas` bedingungslos 401 und der Admin-Bereich ist niemals offen wegen
# einer fehlenden Env-Var.

ATLAS_USER=philipp
ATLAS_PASS=

# --- Store affiliate tags (Brief 105 — empty today) -------------------------
# Optional. The buy/listen links (src/lib/store-links.ts) ship tag-free today.
# Inject affiliate tags WITHOUT a code change by setting this, format:
#   service:tld=tag,service:tld=tag
#   e.g.  amazon:com=chronolex-20,amazon:co.uk=chronolex-21,amazon:de=chronolex-03
# Services: amazon | audible | black_library. Leave unset to keep links tag-free
# (current default). Server-only — NEVER prefix with NEXT_PUBLIC_.
# STORE_AFFILIATE_TAGS=
