# =============================================================================
# Chrono Lexicanum — environment variables
# Copy this file to `.env.local` and fill in real values. .env.local is gitignored.
# =============================================================================

# --- Postgres (Supabase) ------------------------------------------------------
# DATABASE_URL — the PRIVILEGED credential (owner role `postgres.<project-ref>`).
# From: Supabase Dashboard → Settings → Database → "Connection string" (URI mode).
# Used by the local apply/ingest/migration scripts (tsx --env-file=.env.local …),
# which deliberately keep the privileged role (Launch S3a). The app runtime moves
# to RUNTIME_DATABASE_URL below (consumer switch + Vercel cutover: S3b).
# Use the "Transaction pooler" URL (port 6543): the free-tier "Direct connection"
# is IPv6-only and unreachable from most networks; the pooler endpoint is IPv4.
# URL-encode special characters in the password (* → %2A, , → %2C, ! → %21).

DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres"

# RUNTIME_DATABASE_URL — the LEAST-PRIVILEGE runtime credential (role
# `chrono_runtime`: SELECT on the enumerated catalogue tables + the
# preview_invite_activations upsert; `submissions` unreadable; server-side
# statement_timeout — contract in scripts/runtime-role.ts). Created once via
# `npm run db:roles -- --create-login` (prints this URL exactly once; pooler
# username is `chrono_runtime.[YOUR-PROJECT-REF]`). Until the S3b cutover the
# runtime still reads DATABASE_URL — this var is used by
# `npm run db:verify-runtime-role` and staged in Vercel ahead of the switch.
# Full lifecycle: scripts/runbooks/db-roles-runbook.md.
RUNTIME_DATABASE_URL=

# MIGRATION_DATABASE_URL — NOT a .env.local variable. It is the GitHub Actions
# secret on the `production-db` environment that the manual migrate workflow
# (.github/workflows/migrate.yml) uses; value = the privileged pooler URL above.
# Local migrations keep using DATABASE_URL via `npm run db:migrate`.

# --- App ---------------------------------------------------------------------
# Used in Open Graph meta and absolute URLs. Set per environment.
# Local: http://localhost:3000
# Vercel preview: leave blank (Vercel injects VERCEL_URL automatically)
# Production: https://chrono-lexicanum.vercel.app (or your custom domain)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Shared secret for `POST /api/revalidate` (on-demand cache invalidation after
# ingestion/apply runs — Report 144 § P.6). Any long random string, e.g.
# `openssl rand -hex 32`. Unset = the endpoint is disabled (503). Server-only —
# NEVER prefix with NEXT_PUBLIC_.
REVALIDATE_TOKEN=

# Target origin for the explicit POST-DEPLOY release revalidation command
# `npm run release:revalidate` (Launch S3a; content-release-runbook Stufe 6).
# Scheme + host only, no trailing slash — e.g. https://www.chrono-lexicanum.com.
# Script-env only (nothing reads this at runtime). Unset = the command refuses
# to run; there is deliberately NO default target baked into the script.
REVALIDATE_BASE_URL=

# --- Timed preview access (Brief 163 — per-person signed invite links) -------
# HMAC signing secret for invite links AND the signed `cl-preview` session
# cookie. Load-bearing (unlike PREVIEW_USER/PREVIEW_PASS, which are a committed
# soft lock) — high-entropy, NEVER committed. Generate with `openssl rand -hex 32`.
# Set the SAME value in Vercel (prod) and in this .env.local, so the local
# console's minting and the server's verifying agree.
#
# REQUIRED IN PROD for invite links to work. If UNSET in prod the feature
# degrades safely to pre-163 behaviour: the gate falls back to the legacy
# `cl-preview === "1"` presence check (NOT fail-open), the password login sets
# that legacy cookie so you can still get in, and invite redemption is disabled
# (an invite link just shows the "invalid/expired" state). The site never
# crashes or locks everyone out over a missing secret.
#
# ⚠ ROTATE TO REVOKE EVERYTHING: changing this value in Vercel + redeploying
# instantly invalidates every outstanding invite link AND every active session
# (they no longer verify). That is the only revocation lever — there is no
# per-link denylist by design.
# Server-only — NEVER prefix with NEXT_PUBLIC_.
PREVIEW_INVITE_SECRET=

# Origin the local invite console is served from, used as the CORS allow-origin
# for the admin-gated `GET /api/preview-invites` activation read. Default
# matches `npm run preview:console` (which serves on http://localhost:4178).
# Only set this if you run the console on a different port. Server-only.
# PREVIEW_CONSOLE_ORIGIN=http://localhost:4178
#
# The activation read endpoint (GET /api/preview-invites) is gated by the SAME
# admin credential as the rest of the admin surface — ATLAS_USER / ATLAS_PASS
# below (sent by the console as an HTTP Basic Authorization header). No separate
# token to manage. The endpoint checks it in-handler (it's excluded from the
# proxy), and it still answers when PREVIEW_INVITE_SECRET is unset.
#
# Operator levers (full notes in scripts/preview-console/template.html):
#   • Invite someone     → `npm run preview:console`, open http://localhost:4178,
#                          enter the secret + admin credential, click Generate,
#                          paste the link. Each link carries its own baked expiry
#                          (default ~3 days, set per-mint).
#   • See what you handed out / which were activated → the same console lists every
#                          link with an active/expired badge + an "activated · time"
#                          overlay fetched from the endpoint.
#   • End everything now  → rotate PREVIEW_INVITE_SECRET in Vercel + redeploy.
#   • Full public launch  → PREVIEW_GATE=off (gate, links, password all moot).

# --- Hardcover.app (optional) -----------------------------------------------
# User-Token für die Hardcover GraphQL API. Optional — wenn leer, deaktiviert
# sich der Hardcover-Crawler still (kein Crash, kein 0-Diff).
# Token-Beschaffung:
#   1. Account auf https://hardcover.app anlegen (kostenlos).
#   2. Settings → Developer / API → Bearer-Token generieren.
#   3. Hier einsetzen.
# NIEMALS committen.

HARDCOVER_API_TOKEN=

# --- Anthropic API (Phase 3c — optional) ------------------------------------
# API-Key für die Claude-LLM-Anreicherungs-Schicht (Sonnet 4.6 + Web-Search).
# Optional — wenn leer, deaktiviert sich der LLM-Crawler still (kein Crash;
# Diff zeigt Per-Book-Sources wie 3b, ohne LLM-Felder).
# Token-Beschaffung:
#   1. Account auf https://console.anthropic.com anlegen.
#   2. „API Keys" → „Create Key" — z.B. `chrono-lexicanum-ingestion`.
#   3. Hier einsetzen (Format: sk-ant-...).
#   4. Optional: Spending-Limit auf $5 setzen, bevor du den ersten 20-Buch-Test
#      startest (Sicherheits-Stop). 20-Buch-Test-Cost-Erwartung: ~$1.50–4.00.
# NIEMALS committen.

ANTHROPIC_API_KEY=

# Modell-Wahl konfigurierbar; default ist Sonnet 4.6. Ein Switch zu Haiku ist
# ein .env-Edit, kein Code-Change. Nur setzen wenn ein anderes Modell gewünscht.
# INGEST_LLM_MODEL=claude-sonnet-4-6

# Brief 110 — Podcast-Ingest (scripts/ingest-podcast.ts) nutzt ein eigenes,
# vom Buch-Pipeline-Modell unabhängiges Knob. Wenn leer, fällt es auf
# INGEST_LLM_MODEL / dessen Default zurück. Step-1-Pilot lief mit Sonnet 4.6.
# PODCAST_LLM_MODEL=claude-sonnet-4-6

# --- YouTube Data API v3 (Brief 130 — luetin09 YouTube-Source) ---------------
# API-Key für den YouTube-Source-Adapter (src/lib/ingestion/podcast/youtube.ts).
# Nur für Shows mit "source": "youtube" in scripts/seed-data/podcast-shows.json
# nötig (RSS-Shows ignorieren ihn). NUR METADATEN — der Adapter lädt niemals
# Video/Audio herunter, nur reine HTTP-GETs gegen die Data API v3.
# Token-Beschaffung:
#   1. Google-Cloud-Projekt anlegen (console.cloud.google.com).
#   2. „YouTube Data API v3" aktivieren (APIs & Services → Library).
#   3. Credentials → „Create credentials" → „API key". (Quota für diesen
#      Use-Case trivial: Voll-Backfill ≈ wenige Dutzend Units gegen 10 000/Tag.)
#   4. Hier einsetzen. NIEMALS committen.
YOUTUBE_API_KEY=

# --- Atlas Admin-Gate (Task 1 Auth-Foundation) ------------------------------
# HTTP-Basic-Auth-Credentials für `/atlas/**` (siehe src/proxy.ts).
# Single-User, ein Passwort für alles. Bei gültigen Credentials reicht der
# Proxy zusätzlich einen `x-atlas-admin: 1`-Request-Header an `/map/**`
# durch — daher steht /map auch dann im Matcher, wenn es selbst öffentlich
# bleibt (kein 401 auf /map).
#
# ATLAS_USER ist optional (Default: `philipp`).
# ATLAS_PASS MUSS in Produktion gesetzt sein — ist es leer/ungesetzt, liefert
# `/atlas` bedingungslos 401 und der Admin-Bereich ist niemals offen wegen
# einer fehlenden Env-Var.

ATLAS_USER=philipp
ATLAS_PASS=

# --- Store affiliate tags (Brief 105 — empty today) -------------------------
# Optional. The buy/listen links (src/lib/store-links.ts) ship tag-free today.
# Inject affiliate tags WITHOUT a code change by setting this, format:
#   service:tld=tag,service:tld=tag
#   e.g.  amazon:com=chronolex-20,amazon:co.uk=chronolex-21,amazon:de=chronolex-03
# Services: amazon | audible | black_library. Leave unset to keep links tag-free
# (current default). Server-only — NEVER prefix with NEXT_PUBLIC_.
# STORE_AFFILIATE_TAGS=
