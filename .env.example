# =============================================================================
# Chrono Lexicanum — environment variables
# Copy this file to `.env.local` and fill in real values. .env.local is gitignored.
# =============================================================================

# --- Supabase (Postgres) ----------------------------------------------------
# Get these from: Supabase Dashboard → your project → Settings → API
# DATABASE_URL is from: Settings → Database → "Connection string" (URI mode)
# Use the "Transaction pooler" URL (port 6543) for both runtime and migrations.
# Free-tier "Direct connection" is IPv6-only and unreachable from most networks;
# the pooler endpoint is IPv4 and works for everything we need at v1 scale.
# URL-encode special characters in the password (* → %2A, , → %2C, ! → %21).

DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres"

# Public, safe to ship in client bundles. Used for read-only browser access.
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# Server-side only. Used by API routes / scripts that need to bypass RLS.
# NEVER prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# --- App ---------------------------------------------------------------------
# Used in Open Graph meta and absolute URLs. Set per environment.
# Local: http://localhost:3000
# Vercel preview: leave blank (Vercel injects VERCEL_URL automatically)
# Production: https://chrono-lexicanum.vercel.app (or your custom domain)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Hardcover.app (optional) -----------------------------------------------
# User-Token für die Hardcover GraphQL API. Optional — wenn leer, deaktiviert
# sich der Hardcover-Crawler still (kein Crash, kein 0-Diff).
# Token-Beschaffung:
#   1. Account auf https://hardcover.app anlegen (kostenlos).
#   2. Settings → Developer / API → Bearer-Token generieren.
#   3. Hier einsetzen.
# NIEMALS committen.

HARDCOVER_API_TOKEN=

# --- Anthropic API (Phase 3c — optional) ------------------------------------
# API-Key für die Claude-LLM-Anreicherungs-Schicht (Sonnet 4.6 + Web-Search).
# Optional — wenn leer, deaktiviert sich der LLM-Crawler still (kein Crash;
# Diff zeigt Per-Book-Sources wie 3b, ohne LLM-Felder).
# Token-Beschaffung:
#   1. Account auf https://console.anthropic.com anlegen.
#   2. „API Keys" → „Create Key" — z.B. `chrono-lexicanum-ingestion`.
#   3. Hier einsetzen (Format: sk-ant-...).
#   4. Optional: Spending-Limit auf $5 setzen, bevor du den ersten 20-Buch-Test
#      startest (Sicherheits-Stop). 20-Buch-Test-Cost-Erwartung: ~$1.50–4.00.
# NIEMALS committen.

ANTHROPIC_API_KEY=

# Modell-Wahl konfigurierbar; default ist Sonnet 4.6. Ein Switch zu Haiku ist
# ein .env-Edit, kein Code-Change. Nur setzen wenn ein anderes Modell gewünscht.
# INGEST_LLM_MODEL=claude-sonnet-4-6
