{
  "name": "chrono-lexicanum",
  "version": "0.1.0",
  "private": true,
  "description": "Chrono Lexicanum — The 41st Millennium Novel Archive. Interactive timeline, galaxy map, and recommendation engine for Warhammer 40k books.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "tsx scripts/migrate.ts && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:reset-for-ssot": "tsx --env-file=.env.local scripts/db-reset-for-ssot.ts",
    "db:apply-override": "tsx --env-file=.env.local scripts/apply-override.ts",
    "check:eras": "tsx scripts/check-eras.ts",
    "ingest:backfill": "tsx --env-file=.env.local scripts/ingest-backfill.ts",
    "import:ssot-roster": "tsx scripts/import-ssot-roster.ts",
    "loop:next": "tsx scripts/loop-next-batch.ts",
    "resolver:next-wave": "tsx scripts/resolver-loop-detect.ts",
    "atlas:regen": "tsx --env-file=.env.local scripts/atlas-regen.ts",
    "brain:lint": "tsx scripts/brain-lint.ts",
    "test:discovery-merge": "tsx scripts/test-discovery-merge.ts",
    "test:resolver": "tsx scripts/test-resolver.ts",
    "test:resolver-data": "tsx scripts/test-resolver-data-integrity.ts",
    "test:resolver-coverage": "tsx scripts/test-resolver-coverage.ts",
    "test:apply-override-dry": "tsx scripts/apply-override-dry.ts",
    "test:synopsis-lint": "tsx scripts/test-synopsis-lint.ts",
    "test:collection-refs": "tsx scripts/test-apply-override-collections.ts",
    "test:audiobook-narrators": "tsx scripts/test-audiobook-narrators.ts",
    "test:loop-next": "tsx scripts/test-loop-next-batch.ts",
    "test:resolver-loop-detect": "tsx scripts/test-resolver-loop-detect.ts",
    "db:seed-resolver-extensions": "tsx --env-file=.env.local scripts/seed-resolver-extensions.ts",
    "analyze:v2-surfaces": "tsx scripts/analyze-v2-surfaces.ts",
    "audit:gap-candidates": "tsx --env-file=.env.local scripts/audit-gap-candidates.ts",
    "backfill:hardcover-rating": "tsx --env-file=.env.local scripts/backfill-hardcover-rating.ts",
    "backfill:goodreads-rating": "tsx --env-file=.env.local scripts/backfill-goodreads-rating.ts",
    "apply:audiobook-narrators": "tsx --env-file=.env.local scripts/apply-audiobook-narrators.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@supabase/supabase-js": "^2.105.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "postgres": "^3.4.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.1",
    "read-excel-file": "^9.0.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
